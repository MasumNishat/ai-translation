{
  "openapi": "3.0.3",
  "info": {
    "title": "Laravel AI Translator API",
    "description": "AI-powered Laravel translation package with Google Gemini API integration, smart caching, and automatic translation management",
    "version": "1.0.0",
    "contact": {
      "name": "Masum",
      "email": "your-email@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/translator",
      "description": "Local development server"
    },
    {
      "url": "https://your-domain.com/api/translator",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Languages",
      "description": "Language management endpoints"
    },
    {
      "name": "Translations",
      "description": "Translation management endpoints"
    },
    {
      "name": "AI Translation",
      "description": "AI-powered auto-translation endpoints"
    },
    {
      "name": "Settings",
      "description": "Package settings management"
    },
    {
      "name": "Language-Country",
      "description": "Language to country mapping"
    }
  ],
  "paths": {
    "/languages": {
      "get": {
        "tags": ["Languages"],
        "summary": "Get all languages",
        "description": "Retrieve a list of all languages in the system",
        "parameters": [
          {
            "name": "active_only",
            "in": "query",
            "description": "Filter to show only active languages",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Language"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Languages"],
        "summary": "Create a new language",
        "description": "Add a new language to the system",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLanguageRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Language created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Language created successfully."
                    },
                    "data": {
                      "$ref": "#/components/schemas/Language"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/languages/{code}": {
      "get": {
        "tags": ["Languages"],
        "summary": "Get a specific language",
        "description": "Retrieve details of a specific language by code",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "description": "Language code (e.g., en, bn, es)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Language"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Language not found"
          }
        }
      },
      "put": {
        "tags": ["Languages"],
        "summary": "Update a language",
        "description": "Update an existing language",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLanguageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Language updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Language"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Languages"],
        "summary": "Delete a language",
        "description": "Delete a language from the system (cannot delete default language)",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Language deleted successfully"
          },
          "422": {
            "description": "Cannot delete default language"
          }
        }
      }
    },
    "/languages/{code}/toggle": {
      "post": {
        "tags": ["Languages"],
        "summary": "Toggle language active status",
        "description": "Activate or deactivate a language",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Language status toggled successfully"
          }
        }
      }
    },
    "/languages/{code}/default": {
      "post": {
        "tags": ["Languages"],
        "summary": "Set language as default",
        "description": "Set a language as the default language",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Language set as default successfully"
          }
        }
      }
    },
    "/translations": {
      "get": {
        "tags": ["Translations"],
        "summary": "Get all translations",
        "description": "Retrieve translations with optional filtering",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query for key or value",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "description": "Filter by language code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "group",
            "in": "query",
            "description": "Filter by translation group",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "default": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Translation"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Translations"],
        "summary": "Create a translation",
        "description": "Create a new translation entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTranslationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Translation created successfully"
          }
        }
      }
    },
    "/translations/{id}": {
      "get": {
        "tags": ["Translations"],
        "summary": "Get a specific translation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Translation"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Translations"],
        "summary": "Update a translation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTranslationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Translation updated successfully"
          }
        }
      },
      "delete": {
        "tags": ["Translations"],
        "summary": "Delete a translation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Translation deleted successfully"
          }
        }
      }
    },
    "/translations/{id}/history": {
      "get": {
        "tags": ["Translations"],
        "summary": "Get translation history",
        "description": "Get audit trail for a specific translation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TranslationHistory"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/translations/groups": {
      "get": {
        "tags": ["Translations"],
        "summary": "Get all translation groups",
        "description": "Get a list of all translation groups",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/translations/clear-cache": {
      "post": {
        "tags": ["Translations"],
        "summary": "Clear translation cache",
        "description": "Clear all translation caches",
        "responses": {
          "200": {
            "description": "Cache cleared successfully"
          }
        }
      }
    },
    "/auto-translate": {
      "post": {
        "tags": ["AI Translation"],
        "summary": "Auto-translate a key",
        "description": "Automatically translate a key to multiple target languages using Google Gemini AI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AutoTranslateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auto-translation completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Translation"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/batch-translate": {
      "post": {
        "tags": ["AI Translation"],
        "summary": "Batch translate multiple keys",
        "description": "Translate multiple keys at once using Google Gemini AI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchTranslateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch translation completed successfully"
          }
        }
      }
    },
    "/settings": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get all settings",
        "description": "Retrieve all package settings",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Setting"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/settings/{key}": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get a specific setting",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "put": {
        "tags": ["Settings"],
        "summary": "Update a setting",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSettingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Setting updated successfully"
          }
        }
      },
      "delete": {
        "tags": ["Settings"],
        "summary": "Delete a setting",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Setting deleted successfully"
          }
        }
      }
    },
    "/language-to-country/{code}": {
      "get": {
        "tags": ["Language-Country"],
        "summary": "Get country info for a language",
        "description": "Get country information mapped to a language code",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "description": "Language code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/CountryInfo"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/countries": {
      "get": {
        "tags": ["Language-Country"],
        "summary": "Get all language-country mappings",
        "description": "Get all language to country mappings",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CountryInfo"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Language": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "code": {
            "type": "string",
            "example": "en"
          },
          "name": {
            "type": "string",
            "example": "English"
          },
          "native_name": {
            "type": "string",
            "example": "English"
          },
          "direction": {
            "type": "string",
            "enum": ["ltr", "rtl"],
            "example": "ltr"
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "is_default": {
            "type": "boolean",
            "example": false
          },
          "country_code": {
            "type": "string",
            "nullable": true,
            "example": "US"
          },
          "region": {
            "type": "string",
            "nullable": true,
            "example": "North America"
          },
          "is_rtl": {
            "type": "boolean",
            "example": false
          },
          "country_info": {
            "$ref": "#/components/schemas/CountryInfo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Translation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "language_id": {
            "type": "integer"
          },
          "language_code": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "nullable": true
          },
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "is_auto_translated": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TranslationHistory": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "translation_id": {
            "type": "integer"
          },
          "old_value": {
            "type": "string",
            "nullable": true
          },
          "new_value": {
            "type": "string"
          },
          "change_type": {
            "type": "string",
            "enum": ["created", "updated", "deleted"]
          },
          "changed_by_user_id": {
            "type": "integer",
            "nullable": true
          },
          "ip_address": {
            "type": "string",
            "nullable": true
          },
          "user_agent": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Setting": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["string", "boolean", "integer", "json"]
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "CountryInfo": {
        "type": "object",
        "properties": {
          "language_code": {
            "type": "string",
            "example": "bn"
          },
          "language_name": {
            "type": "string",
            "example": "Bengali"
          },
          "country": {
            "type": "string",
            "example": "Bangladesh"
          },
          "country_code": {
            "type": "string",
            "example": "BD"
          },
          "region": {
            "type": "string",
            "example": "Asia"
          }
        }
      },
      "CreateLanguageRequest": {
        "type": "object",
        "required": ["code", "name", "native_name", "direction"],
        "properties": {
          "code": {
            "type": "string",
            "maxLength": 10,
            "example": "en"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "example": "English"
          },
          "native_name": {
            "type": "string",
            "maxLength": 255,
            "example": "English"
          },
          "direction": {
            "type": "string",
            "enum": ["ltr", "rtl"],
            "example": "ltr"
          },
          "is_active": {
            "type": "boolean",
            "default": true
          },
          "is_default": {
            "type": "boolean",
            "default": false
          },
          "country_code": {
            "type": "string",
            "maxLength": 2,
            "nullable": true,
            "example": "US"
          },
          "region": {
            "type": "string",
            "maxLength": 255,
            "nullable": true,
            "example": "North America"
          }
        }
      },
      "UpdateLanguageRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "native_name": {
            "type": "string",
            "maxLength": 255
          },
          "direction": {
            "type": "string",
            "enum": ["ltr", "rtl"]
          },
          "is_active": {
            "type": "boolean"
          },
          "is_default": {
            "type": "boolean"
          },
          "country_code": {
            "type": "string",
            "maxLength": 2,
            "nullable": true
          },
          "region": {
            "type": "string",
            "maxLength": 255,
            "nullable": true
          }
        }
      },
      "CreateTranslationRequest": {
        "type": "object",
        "required": ["key", "value", "language_code"],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 255,
            "example": "welcome.title"
          },
          "value": {
            "type": "string",
            "example": "Welcome to our website"
          },
          "language_code": {
            "type": "string",
            "example": "en"
          },
          "group": {
            "type": "string",
            "maxLength": 255,
            "nullable": true,
            "example": "home"
          }
        }
      },
      "UpdateTranslationRequest": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "AutoTranslateRequest": {
        "type": "object",
        "required": ["key", "value", "source_language", "target_languages"],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 255,
            "example": "button.submit"
          },
          "value": {
            "type": "string",
            "example": "Submit"
          },
          "source_language": {
            "type": "string",
            "example": "en"
          },
          "target_languages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "example": ["bn", "es", "fr"]
          },
          "group": {
            "type": "string",
            "maxLength": 255,
            "nullable": true,
            "example": "common"
          }
        }
      },
      "BatchTranslateRequest": {
        "type": "object",
        "required": ["translations", "source_language", "target_languages"],
        "properties": {
          "translations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "button.save": "Save",
              "button.cancel": "Cancel",
              "button.delete": "Delete"
            }
          },
          "source_language": {
            "type": "string",
            "example": "en"
          },
          "target_languages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["bn", "es"]
          },
          "group": {
            "type": "string",
            "nullable": true,
            "example": "common"
          }
        }
      },
      "UpdateSettingRequest": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["string", "boolean", "integer", "json"],
            "default": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "The given data was invalid."
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
